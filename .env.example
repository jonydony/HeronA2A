# Copy to .env for local dev, or set these in Railway (see DEPLOY.md).
# All optional — with none set, Heron runs the file store + deterministic tier.

# Postgres (Supabase). Set this to use the Postgres store instead of flat files.
# Supabase -> Settings -> Database -> Connection string -> URI.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.ovazlgwrmjzajvcfakac.supabase.co:5432/postgres

# Smart conformance judging via any OpenAI-compatible endpoint (e.g. a LiteLLM proxy).
# Omit to run the free deterministic tier.
# HERON_LLM_API_KEY=
# HERON_LLM_BASE_URL=https://litellm.theona.ai/v1
# HERON_LLM_MODEL=gpt-4o-mini
# HERON_LLM_MAX_CALLS=50   # per-process cap; past it, falls back to deterministic

# Stable signing identity across redeploys (base64 ed25519 seed).
# Generate: python -c "from app import sign; print(sign.private_seed_b64())"
# HERON_SIGNING_KEY=

# Optional tuning
# HERON_MODE=deterministic
# HERON_RATE_LIMIT_PER_HOUR=30
